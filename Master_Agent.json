    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  let text = item.json.output || \"\"; // Sesuaikan nama properti output AI Anda\n\n  // 1. Ubah Bold Markdown (**teks**) menjadi Bold WhatsApp (*teks*)\n  // Menggunakan regex untuk menangkap teks di antara ** dan menggantinya dengan *\n  text = text.replace(/\\*\\*(.*?)\\*\\*/g, '*$1*');\n\n  // 2. Ubah Headers (### Judul) menjadi Bold Uppercase\n  // WhatsApp tidak mendukung header, jadi kita ubah jadi huruf kapital tebal\n  text = text.replace(/^#+\\s*(.*)$/gm, (match, p1) => {\n    return '*' + p1.toUpperCase() + '*';\n  });\n\n  // 3. Rapikan Unordered List\n  // Kadang AI pakai '*' untuk list yang bentrok dengan Bold WA. \n  // Kita pastikan list menggunakan bullet point '•' atau '-'\n  text = text.replace(/^\\s*\\*\\s+/gm, '• ');\n\n  // 4. Hapus Escaped Characters\n  // Kadang AI menambahkan backslash sebelum karakter spesial (seperti \\_ atau \\*)\n  text = text.replace(/\\\\([\\_\\*\\[\\]\\(\\)#\\+\\-\\.!\\{\\}])/g, '$1');\n\n  // 5. Normalisasi Spasi Baris (Line Breaks)\n  // Memastikan tidak ada lebih dari dua enter berurutan agar chat tidak terlalu panjang\n  text = text.replace(/\\n{3,}/g, '\\n\\n');\n\n  // 6. Pastikan Link tetap aman\n  // WhatsApp otomatis merender link, jadi kita hanya bersihkan jika ada format [text](url)\n  text = text.replace(/\\[(.*?)\\]\\((.*?)\\)/g, '$1: $2');\n\n  // Masukkan kembali teks yang sudah bersih ke dalam item\n  item.json.output = text.trim();\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
